# ──────────────────────────────────────────────────────────────────
# Frontend environment variables
# Copy this file to .env.local and fill in the values.
# On Render: set these in the "Environment" tab of your static site.
# ──────────────────────────────────────────────────────────────────

# Backend API base URL
# Local: http://localhost:60588/api
# Render: https://<your-api-service>.onrender.com/api
VITE_API_URL=http://localhost:60588/api

# Google OAuth Client ID (used for "Sign up / Login with Google")
#
# How to get it:
#   1. Go to https://console.cloud.google.com/
#   2. Create a project (or select an existing one)
#   3. APIs & Services → Credentials → Create Credentials → OAuth client ID
#   4. Application type: Web application
#   5. Authorised JavaScript origins:
#        http://localhost:5173          (local dev)
#        https://<your-frontend>.onrender.com   (production)
#   6. Authorised redirect URIs: leave empty (GIS uses postMessage, not redirects)
#   7. Click Create → copy the Client ID shown
#
# Also set the same value as GoogleAuth__ClientId on your Render API service
# so the backend can validate the token audience.
#
VITE_GOOGLE_CLIENT_ID=
